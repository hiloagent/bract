{
  "name": "@losoft/bract-cli",
  "version": "0.0.1",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "bin": {
    "bract": "./dist/bract"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "node": "./dist/node/index.js",
      "import": "./dist/node/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build:bun": "bun build ./src/index.ts --outdir ./dist/bun --target bun",
    "build:node": "bun build ./src/index.ts --outdir ./dist/node --format esm --target node --packages external",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/types",
    "build:cli": "bun build ./src/index.ts --outfile dist/bract --compile",
    "build": "bun run build:bun && bun run build:node && bun run build:types && bun run build:cli",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@losoft/bract-runtime": "workspace:*",
    "@losoft/bract-runner": "workspace:*",
    "@losoft/bract-supervisor": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1",
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0"
  }
}
