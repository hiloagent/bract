{
  "name": "@losoft/bract-supervisor",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "node": "./dist/node/index.js",
      "import": "./dist/node/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build:bun": "bun build ./src/index.ts --outdir ./dist/bun",
    "build:node": "bun build ./src/index.ts --outdir ./dist/node --format esm --target node --packages external",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build": "npm run build:bun && npm run build:node && npm run build:types",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@losoft/bract-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1",
    "typescript": "^5.4.0"
  }
}
